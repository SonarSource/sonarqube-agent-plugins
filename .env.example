# SonarQube Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===== FOR SONARQUBE CLOUD (Default: EU) =====
# Most users are on the EU region
# Uncomment these lines if using SonarCloud
export SONARQUBE_URL="https://sonarcloud.io"
export SONARQUBE_ORG="your-organization-key"
export SONARQUBE_TOKEN="your-token-here"

# ===== FOR SONARQUBE CLOUD (US Region) =====
# Only use this if you access SonarCloud at sonarqube.us
# Uncomment these lines and comment out the EU section above
# export SONARQUBE_URL="https://sonarqube.us"
# export SONARQUBE_ORG="your-organization-key"
# export SONARQUBE_TOKEN="your-token-here"

# ===== FOR SONARQUBE SERVER =====
# Uncomment these lines if using self-hosted SonarQube
# Your SonarQube server URL
# Examples:
#   - Local: http://localhost:9000
#   - Enterprise: https://sonarqube.yourcompany.com
export SONARQUBE_URL="http://localhost:9000"
export SONARQUBE_TOKEN="your-token-here"

# NOTE: SONARQUBE_ORG is only required for SonarQube Cloud
# For SonarQube Server, do NOT set SONARQUBE_ORG

# Generate tokens at:
#   - SonarCloud: https://sonarcloud.io/account/security
#   - SonarQube Server: User → My Account → Security → Generate Tokens
