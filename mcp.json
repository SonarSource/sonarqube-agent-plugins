{
    "mcpServers": {
      "sonarqube": {
        "command": "docker",
        "args": [
          "run",
          "--init",
          "--pull=always",
          "-i",
          "--rm",
          "-e",
          "SONARQUBE_URL",
          "-e",
          "SONARQUBE_TOKEN",
          "-e",
          "SONARQUBE_ORG",
          "mcp/sonarqube"
        ],
        "env": {
          "SONARQUBE_URL": "${SONARQUBE_URL}",
          "SONARQUBE_TOKEN": "${SONARQUBE_TOKEN}",
          "SONARQUBE_ORG": "${SONARQUBE_ORG}"
        }
      }
    }
  }